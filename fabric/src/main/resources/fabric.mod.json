{
  "schemaVersion": 1,
  "id": "automobility",
  "version": "${version}",
  "name": "Automobility",
  "description": "Unofficial Automobility Fabric port for Minecraft 26.1.2.",
  "authors": [
    "FoundationGames"
  ],
  "contact": {
    "homepage": "https://modrinth.com/project/automobility-unofficial-port",
    "sources": ""
  },
  "license": "MIT",
  "icon": "automobility.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "io.github.foundationgames.automobility.fabric.AutomobilityFabric"
    ],
    "client": [
      "io.github.foundationgames.automobility.fabric.AutomobilityClientFabric"
    ],
    "controlify": [
      "io.github.foundationgames.automobility.fabric.controller.controlify.ControlifyCompat"
    ]
  },
  "mixins": [
    "automobility.mixins.json",
    "automobility_fabric.mixins.json"
  ],
  "accessWidener" : "automobility.accesswidener",
  "depends": {
    "fabricloader": ">=0.19.2",
    "fabric-api": "*",
    "minecraft": "26.1.x",
    "java": ">=25"
  }
}
