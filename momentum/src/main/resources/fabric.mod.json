{
  "schemaVersion": 1,
  "id": "momentum",
  "version": "${version}",
  "name": "Momentum for Automobility",
  "description": "An Automobility addon that improves car movement feel and adds a better HUD.",
  "authors": ["milkucha"],
  "license": "MIT",
  "icon": "momentum_icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "io.github.milkucha.momentum.Momentum"
    ],
